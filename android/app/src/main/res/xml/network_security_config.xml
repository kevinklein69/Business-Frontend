<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- DEV ONLY: allow plain-HTTP to the local .NET API during development.
         10.0.2.2 = the host machine as seen from the Android emulator; localhost for
         completeness. Production must use HTTPS — remove these exceptions before release. -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">localhost</domain>
    </domain-config>
</network-security-config>
